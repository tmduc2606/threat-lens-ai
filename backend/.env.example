# ThreatLensAI Backend — Environment Configuration
# Copy this file to .env and fill in your credentials.

# --- App Settings ---
APP_NAME=ThreatLensAI API
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/threatlensai
CORS_ORIGINS=*

# --- API Keys (free tiers) ---
# Sign up at https://abuseipdb.com (1,000 checks/day)
ABUSEIPDB_API_KEY=
# Sign up at https://otx.alienvault.com (unlimited)
OTX_API_KEY=
# Sign up at https://nvd.nist.gov (50 req/30s with key)
NVD_API_KEY=
# Sign up at https://virustotal.com (500 req/day)
VIRUSTOTAL_API_KEY=
# Sign up at https://urlscan.io (free tier)
URLSCAN_API_KEY=
# Get key at https://threatfox.abuse.ch (free)
THREATFOX_AUTH_KEY=
# Get key at https://urlhaus.abuse.ch (free)
URLHAUS_AUTH_KEY=
# Get key at https://malwarebazaar.abuse.ch (free)
MALWAREBAZAAR_AUTH_KEY=
# Sign up at https://whoisjson.com (1,000/month)
WHOISJSON_API_KEY=

# --- Cache TTLs (seconds) ---
CACHE_TTL_IP=86400
CACHE_TTL_DOMAIN=259200
CACHE_TTL_CVE=604800
CACHE_TTL_OTX=604800

# --- Feature Flags ---
ENABLE_ML_MODEL=true
ENABLE_NMAP_SCAN=false
ENABLE_LLM_FALLBACK=false

# --- Model Settings ---
JOBLIB_MODEL_PATH=
MODELS_DIR=../models

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# --- Rate Limits ---
NVD_RATE_LIMIT=5
ABUSEIPDB_DAILY_LIMIT=1000
